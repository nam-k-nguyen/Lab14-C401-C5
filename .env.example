# Copy file này thành .env và điền giá trị thật. KHÔNG commit .env lên Git.

# OpenAI — dùng cho Judge thứ nhất (GPT-4o) và SDG (synthetic data generation)
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — dùng cho Judge thứ hai (Gemini 1.5 Pro)
# Lấy tại: https://aistudio.google.com/apikey
GOOGLE_API_KEY=...

# (Tuỳ chọn) model override
OPENAI_JUDGE_MODEL=gpt-4o
OPENAI_TIE_BREAKER_MODEL=gpt-4o-mini
GOOGLE_JUDGE_MODEL=gemini-1.5-pro
